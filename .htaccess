<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Block direct access to application internals and local secrets.
    RewriteRule (^|/)\. - [F,L]
    RewriteRule ^(app|bootstrap|config|database|resources|routes|tests|vendor)(/|$) - [F,L]
    RewriteRule ^(artisan|composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|vite\.config\.js|auth\.json|README\.md|INSTALL-XAMPP\.md|RELEASE-MANIFEST\.txt)$ - [F,L]

    # Serve public assets while the project lives directly inside htdocs/lulu.
    RewriteRule ^(build|css|fonts|images|js)(/.*)?$ public/$0 [L]
    RewriteRule ^(favicon\.ico|robots\.txt)$ public/$1 [L]
    RewriteRule ^storage(/.*)?$ index.php [L]

    # Let existing root files resolve normally after the deny rules above.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Send all Laravel routes to the root front controller.
    RewriteRule ^ index.php [L]
</IfModule>
